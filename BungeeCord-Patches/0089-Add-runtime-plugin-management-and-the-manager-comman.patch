+package net.regksem.xwaterfall.command;
+
+import java.io.File;
+import java.util.ArrayList;
+import java.util.Collection;
+import java.util.HashSet;
+import java.util.List;
+import java.util.Locale;
+import java.util.Set;
+import net.md_5.bungee.api.ChatColor;
+import net.md_5.bungee.api.CommandSender;
+import net.md_5.bungee.api.ProxyServer;
+import net.md_5.bungee.api.plugin.Command;
+import net.md_5.bungee.api.plugin.Plugin;
+import net.md_5.bungee.api.plugin.PluginManager;
+import net.md_5.bungee.api.plugin.TabExecutor;
+
+/**
+ * PlugMan-style runtime management of plugins and modules. Modules are simply
+ * plugins loaded from the {@code modules/} folder, so both are managed the same
+ * way.
+ *
+ * <p>{@code /manager list [plugins|modules]}, {@code info <name>},
+ * {@code load <jar>}, {@code unload <name>}, {@code reload <name>},
+ * {@code enable <name>} and {@code disable <name>}.</p>
+ *
+ * <p>Unloading tears down everything the proxy tracks for a plugin (commands,
+ * listeners, scheduled tasks, executor and class loader); a plugin that leaks
+ * its own references may still not unload completely.</p>
+ */
+public class CommandManager extends Command implements TabExecutor
+{
+
+    private static final String[] SUBCOMMANDS =
+    {
+        "list", "info", "load", "unload", "reload", "enable", "disable"
+    };
+
+    public CommandManager()
+    {
+        super( "manager", "bungeecord.command.manager", "plugman" );
+    }
+
+    private static PluginManager pm()
+    {
+        return ProxyServer.getInstance().getPluginManager();
+    }
+
+    @Override
+    public void execute(CommandSender sender, String[] args)
+    {
+        if ( args.length == 0 )
+        {
+            usage( sender );
+            return;
+        }
+
+        String sub = args[0].toLowerCase( Locale.ROOT );
+        switch ( sub )
+        {
+            case "list":
+                list( sender, ( args.length > 1 ) ? args[1].toLowerCase( Locale.ROOT ) : "all" );
+                return;
+            case "info":
+                requireName( sender, args, this::info );
+                return;
+            case "load":
+                requireName( sender, args, this::load );
+                return;
+            case "unload":
+                requireName( sender, args, this::unload );
+                return;
+            case "reload":
+                requireName( sender, args, this::reload );
+                return;
+            case "enable":
+                requireName( sender, args, this::enable );
+                return;
+            case "disable":
+                requireName( sender, args, this::disable );
+                return;
+            default:
+                usage( sender );
+        }
+    }
+
+    private interface NameAction
+    {
+        void run(CommandSender sender, String name);
+    }
+
+    private void requireName(CommandSender sender, String[] args, NameAction action)
+    {
+        if ( args.length < 2 )
+        {
+            sender.sendMessage( ChatColor.RED + "Usage: /manager " + args[0].toLowerCase( Locale.ROOT ) + " <name>" );
+            return;
+        }
+        action.run( sender, args[1] );
+    }
+
+    private void usage(CommandSender sender)
+    {
+        sender.sendMessage( ChatColor.GOLD + "/manager " + ChatColor.GRAY + "- manage plugins and modules" );
+        sender.sendMessage( ChatColor.YELLOW + "  list [plugins|modules]" + ChatColor.GRAY + " - list loaded plugins/modules" );
+        sender.sendMessage( ChatColor.YELLOW + "  info <name>" + ChatColor.GRAY + " - show details about a plugin" );
+        sender.sendMessage( ChatColor.YELLOW + "  load <jar>" + ChatColor.GRAY + " - load a jar from plugins/ or modules/" );
+        sender.sendMessage( ChatColor.YELLOW + "  unload <name>" + ChatColor.GRAY + " - unload a plugin" );
+        sender.sendMessage( ChatColor.YELLOW + "  reload <name>" + ChatColor.GRAY + " - unload and load a plugin again" );
+        sender.sendMessage( ChatColor.YELLOW + "  enable|disable <name>" + ChatColor.GRAY + " - toggle a loaded plugin" );
+    }
+
+    private void list(CommandSender sender, String filter)
+    {
+        boolean wantModules = filter.startsWith( "mod" );
+        boolean wantPlugins = filter.startsWith( "plug" );
+        boolean all = !wantModules && !wantPlugins;
+
+        List<String> entries = new ArrayList<>();
+        for ( Plugin plugin : pm().getPlugins() )
+        {
+            boolean module = isModule( plugin );
+            if ( !all && ( module != wantModules ) )
+            {
+                continue;
+            }
+            ChatColor state = pm().isPluginEnabled( plugin ) ? ChatColor.GREEN : ChatColor.RED;
+            String tag = module ? ChatColor.AQUA + "[M]" : ChatColor.BLUE + "[P]";
+            entries.add( tag + " " + state + plugin.getDescription().getName() );
+        }
+
+        String header = all ? "Plugins & modules" : ( wantModules ? "Modules" : "Plugins" );
+        sender.sendMessage( ChatColor.GOLD + header + " (" + entries.size() + "):" );
+        if ( entries.isEmpty() )
+        {
+            sender.sendMessage( ChatColor.GRAY + "  (none)" );
+            return;
+        }
+        sender.sendMessage( ChatColor.GRAY + "  " + String.join( ChatColor.GRAY + ", ", entries ) );
+    }
+
+    private void info(CommandSender sender, String name)
+    {
+        Plugin plugin = find( name );
+        if ( plugin == null )
+        {
+            notFound( sender, name );
+            return;
+        }
+        sender.sendMessage( ChatColor.GOLD + "===== " + plugin.getDescription().getName() + " =====" );
+        sender.sendMessage( ChatColor.YELLOW + "Version: " + ChatColor.WHITE + plugin.getDescription().getVersion() );
+        sender.sendMessage( ChatColor.YELLOW + "Author: " + ChatColor.WHITE + plugin.getDescription().getAuthor() );
+        if ( plugin.getDescription().getDescription() != null )
+        {
+            sender.sendMessage( ChatColor.YELLOW + "Description: " + ChatColor.WHITE + plugin.getDescription().getDescription() );
+        }
+        sender.sendMessage( ChatColor.YELLOW + "Type: " + ChatColor.WHITE + ( isModule( plugin ) ? "module" : "plugin" ) );
+        sender.sendMessage( ChatColor.YELLOW + "State: " + ( pm().isPluginEnabled( plugin ) ? ChatColor.GREEN + "enabled" : ChatColor.RED + "disabled" ) );
+        sender.sendMessage( ChatColor.YELLOW + "File: " + ChatColor.WHITE + plugin.getDescription().getFile().getName() );
+
+        Collection<Command> commands = pm().getCommands( plugin );
+        if ( !commands.isEmpty() )
+        {
+            Set<String> names = new HashSet<>();
+            for ( Command command : commands )
+            {
+                names.add( command.getName() );
+            }
+            sender.sendMessage( ChatColor.YELLOW + "Commands: " + ChatColor.WHITE + String.join( ", ", names ) );
+        }
+    }
+
+    private void load(CommandSender sender, String name)
+    {
+        File file = resolveJar( name );
+        if ( file == null )
+        {
+            sender.sendMessage( ChatColor.RED + "No jar named '" + name + "' found in plugins/ or modules/." );
+            return;
+        }
+        try
+        {
+            Plugin plugin = pm().loadPlugin( file );
+            sender.sendMessage( ChatColor.GREEN + "Loaded and enabled " + plugin.getDescription().getName() + "." );
+        } catch ( Throwable t )
+        {
+            sender.sendMessage( ChatColor.RED + "Could not load " + file.getName() + ": " + rootMessage( t ) );
+            ProxyServer.getInstance().getLogger().warning( "Failed to load plugin " + file + " via /manager: " + rootMessage( t ) );
+        }
+    }
+
+    private void unload(CommandSender sender, String name)
+    {
+        Plugin plugin = find( name );
+        if ( plugin == null )
+        {
+            notFound( sender, name );
+            return;
+        }
+        String display = plugin.getDescription().getName();
+        pm().unloadPlugin( plugin );
+        sender.sendMessage( ChatColor.GREEN + "Unloaded " + display + "." );
+    }
+
+    private void reload(CommandSender sender, String name)
+    {
+        Plugin plugin = find( name );
+        if ( plugin == null )
+        {
+            notFound( sender, name );
+            return;
+        }
+        String display = plugin.getDescription().getName();
+        try
+        {
+            Plugin reloaded = pm().reloadPlugin( plugin );
+            sender.sendMessage( ChatColor.GREEN + "Reloaded " + reloaded.getDescription().getName() + "." );
+        } catch ( Throwable t )
+        {
+            sender.sendMessage( ChatColor.RED + display + " was unloaded but could not be loaded again: " + rootMessage( t ) );
+            ProxyServer.getInstance().getLogger().warning( "Failed to reload plugin " + display + " via /manager: " + rootMessage( t ) );
+        }
+    }
+
+    private void enable(CommandSender sender, String name)
+    {
+        Plugin plugin = find( name );
+        if ( plugin == null )
+        {
+            notFound( sender, name );
+            return;
+        }
+        if ( pm().isPluginEnabled( plugin ) )
+        {
+            sender.sendMessage( ChatColor.RED + plugin.getDescription().getName() + " is already enabled." );
+            return;
+        }
+        pm().enablePlugin( plugin );
+        sender.sendMessage( ChatColor.GREEN + "Enabled " + plugin.getDescription().getName() + "." );
+    }
+
+    private void disable(CommandSender sender, String name)
+    {
+        Plugin plugin = find( name );
+        if ( plugin == null )
+        {
+            notFound( sender, name );
+            return;
+        }
+        if ( !pm().isPluginEnabled( plugin ) )
+        {
+            sender.sendMessage( ChatColor.RED + plugin.getDescription().getName() + " is already disabled." );
+            return;
+        }
+        pm().disablePlugin( plugin );
+        sender.sendMessage( ChatColor.GREEN + "Disabled " + plugin.getDescription().getName() + "." );
+    }
+
+    private static Plugin find(String name)
+    {
+        for ( Plugin plugin : pm().getPlugins() )
+        {
+            if ( plugin.getDescription().getName().equalsIgnoreCase( name ) )
+            {
+                return plugin;
+            }
+        }
+        return null;
+    }
+
+    private static boolean isModule(Plugin plugin)
+    {
+        File file = plugin.getDescription().getFile();
+        File parent = ( file == null ) ? null : file.getParentFile();
+        return parent != null && "modules".equalsIgnoreCase( parent.getName() );
+    }
+
+    private static File resolveJar(String name)
+    {
+        String jarName = name.toLowerCase( Locale.ROOT ).endsWith( ".jar" ) ? name : name + ".jar";
+        File[] folders =
+        {
+            ProxyServer.getInstance().getPluginsFolder(), new File( "modules" )
+        };
+        for ( File folder : folders )
+        {
+            if ( folder == null || !folder.isDirectory() )
+            {
+                continue;
+            }
+            File candidate = new File( folder, jarName );
+            if ( candidate.isFile() )
+            {
+                return candidate;
+            }
+        }
+        return null;
+    }
+
+    private static String rootMessage(Throwable t)
+    {
+        Throwable cause = t;
+        while ( cause.getCause() != null && cause.getCause() != cause )
+        {
+            cause = cause.getCause();
+        }
+        String message = cause.getMessage();
+        return ( message == null ) ? cause.getClass().getSimpleName() : message;
+    }
+
+    private static void notFound(CommandSender sender, String name)
+    {
+        sender.sendMessage( ChatColor.RED + "No plugin or module named '" + name + "' is loaded." );
+    }
+
+    @Override
+    public Iterable<String> onTabComplete(CommandSender sender, String[] args)
+    {
+        Set<String> matches = new HashSet<>();
+        if ( args.length == 1 )
+        {
+            String search = args[0].toLowerCase( Locale.ROOT );
+            for ( String sub : SUBCOMMANDS )
+            {
+                if ( sub.startsWith( search ) )
+                {
+                    matches.add( sub );
+                }
+            }
+            return matches;
+        }
+        if ( args.length == 2 )
+        {
+            String sub = args[0].toLowerCase( Locale.ROOT );
+            String search = args[1].toLowerCase( Locale.ROOT );
+            if ( sub.equals( "list" ) )
+            {
+                for ( String option : new String[]
+                {
+                    "plugins", "modules"
+                } )
+                {
+                    if ( option.startsWith( search ) )
+                    {
+                        matches.add( option );
+                    }
+                }
+            } else if ( sub.equals( "load" ) )
+            {
+                collectJarNames( matches, search );
+            } else
+            {
+                for ( Plugin plugin : pm().getPlugins() )
+                {
+                    if ( plugin.getDescription().getName().toLowerCase( Locale.ROOT ).startsWith( search ) )
+                    {
+                        matches.add( plugin.getDescription().getName() );
+                    }
+                }
+            }
+        }
+        return matches;
+    }
+
+    private static void collectJarNames(Set<String> matches, String search)
+    {
+        File[] folders =
+        {
+            ProxyServer.getInstance().getPluginsFolder(), new File( "modules" )
+        };
+        for ( File folder : folders )
+        {
