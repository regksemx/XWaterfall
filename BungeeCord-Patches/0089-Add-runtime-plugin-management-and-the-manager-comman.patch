+    // XWaterfall start - runtime plugin management for the /manager command
+
+    /**
+     * Loads, registers and enables a single plugin from the given jar at
+     * runtime. The jar must contain a {@code bungee.yml} or {@code plugin.yml}.
+     *
+     * @param file the plugin jar to load
+     * @return the loaded plugin
+     * @throws Exception if the jar has no descriptor, names an already-loaded
+     * plugin, or fails to enable
+     */
+    public Plugin loadPlugin(File file) throws Exception
+    {
+        Preconditions.checkNotNull( file, "file" );
+        Preconditions.checkArgument( file.isFile(), "%s is not a file", file );
+
+        PluginDescription desc = describePlugin( file );
+        Preconditions.checkNotNull( desc.getName(), "Plugin from %s has no name", file );
+        Preconditions.checkNotNull( desc.getMain(), "Plugin from %s has no main", file );
+        Preconditions.checkArgument( plugins.get( desc.getName() ) == null, "Plugin %s is already loaded", desc.getName() );
+
+        URLClassLoader loader = new PluginClassloader( proxy, desc, desc.getFile(), ( libraryLoader != null ) ? libraryLoader.createLoader( desc ) : null );
+        Class<?> main = loader.loadClass( desc.getMain() );
+        Plugin plugin = (Plugin) main.getDeclaredConstructor().newInstance();
+
+        plugins.put( desc.getName(), plugin );
+        try
+        {
+            plugin.onLoad();
+            plugin.onEnable();
+        } catch ( Throwable t )
+        {
+            // Roll back a half-loaded plugin so it can be retried cleanly.
+            proxy.getLogger().log( Level.WARNING, "Error enabling plugin " + desc.getName(), t );
+            unloadPlugin( plugin );
+            throw new IllegalStateException( "Could not enable plugin " + desc.getName(), t );
+        }
+        ProxyServer.getInstance().getLogger().log( Level.INFO, "Loaded plugin {0} version {1} by {2}", new Object[]
+        {
+            desc.getName(), desc.getVersion(), desc.getAuthor()
+        } );
+        return plugin;
+    }
+
+    /**
+     * Disables and fully unloads a plugin: its scheduled tasks, commands and
+     * listeners are removed, its executor is shut down and its class loader is
+     * closed. References the plugin leaked elsewhere (static caches, threads it
+     * started itself) cannot be reclaimed.
+     *
+     * @param plugin the plugin to unload
+     * @return true once unloaded
+     */
+    public boolean unloadPlugin(Plugin plugin)
+    {
+        Preconditions.checkNotNull( plugin, "plugin" );
+        String name = plugin.getDescription().getName();
+
+        try
+        {
+            plugin.onDisable();
+        } catch ( Throwable t )
+        {
+            proxy.getLogger().log( Level.WARNING, "Exception disabling plugin " + name, t );
+        }
+
+        proxy.getScheduler().cancel( plugin );
+        plugin.shutdownExecutorService();
+        unregisterCommands( plugin );
+        unregisterListeners( plugin );
+
+        plugins.remove( name );
+        disabledPlugins.remove( name );
+        if ( dependencyGraph.nodes().contains( name ) )
+        {
+            dependencyGraph.removeNode( name );
+        }
+
+        ClassLoader loader = plugin.getClass().getClassLoader();
+        if ( loader instanceof PluginClassloader )
+        {
+            try
+            {
+                ( (PluginClassloader) loader ).close();
+            } catch ( IOException ex )
+            {
+                proxy.getLogger().log( Level.WARNING, "Could not close class loader for plugin " + name, ex );
+            }
+        }
+        return true;
+    }
+
+    /**
+     * Unloads and then loads the plugin again from its jar on disk.
+     *
+     * @param plugin the plugin to reload
+     * @return the freshly loaded plugin
+     * @throws Exception if loading the plugin again fails
+     */
+    public Plugin reloadPlugin(Plugin plugin) throws Exception
+    {
+        Preconditions.checkNotNull( plugin, "plugin" );
+        File file = plugin.getDescription().getFile();
+        unloadPlugin( plugin );
+        return loadPlugin( file );
+    }
+
+    /**
+     * Soft-disables a loaded plugin: it stays loaded but its tasks, commands and
+     * listeners are removed and {@link Plugin#onDisable()} is called. Use
+     * {@link #enablePlugin(Plugin)} to bring it back.
+     *
+     * @param plugin the plugin to disable
+     */
+    public void disablePlugin(Plugin plugin)
+    {
+        Preconditions.checkNotNull( plugin, "plugin" );
+        String name = plugin.getDescription().getName();
+        if ( disabledPlugins.contains( name ) )
+        {
+            return;
+        }
+        try
+        {
+            plugin.onDisable();
+        } catch ( Throwable t )
+        {
+            proxy.getLogger().log( Level.WARNING, "Exception disabling plugin " + name, t );
+        }
+        proxy.getScheduler().cancel( plugin );
+        unregisterCommands( plugin );
+        unregisterListeners( plugin );
+        disabledPlugins.add( name );
+    }
+
+    /**
+     * Re-enables a plugin previously soft-disabled with
+     * {@link #disablePlugin(Plugin)} by calling {@link Plugin#onEnable()} again.
+     *
+     * @param plugin the plugin to enable
+     */
+    public void enablePlugin(Plugin plugin)
+    {
+        Preconditions.checkNotNull( plugin, "plugin" );
+        String name = plugin.getDescription().getName();
+        if ( !disabledPlugins.contains( name ) )
+        {
+            return;
+        }
+        disabledPlugins.remove( name );
+        try
+        {
+            plugin.onEnable();
+        } catch ( Throwable t )
+        {
+            proxy.getLogger().log( Level.WARNING, "Exception enabling plugin " + name, t );
+        }
+    }
+
+    /**
+     * Whether the given plugin is currently enabled (loaded and not
+     * soft-disabled).
+     *
+     * @param plugin the plugin to query
+     * @return true if enabled
+     */
+    public boolean isPluginEnabled(Plugin plugin)
+    {
+        return plugin != null && !disabledPlugins.contains( plugin.getDescription().getName() );
+    }
+
+    /**
+     * Returns a copy of the commands registered by the given plugin.
+     *
+     * @param plugin the owning plugin
+     * @return the plugin's registered commands
+     */
+    @Locked.Read("commandsLock")
+    public Collection<Command> getCommands(Plugin plugin)
+    {
+        return new java.util.ArrayList<>( commandsByPlugin.get( plugin ) );
+    }
+
+    private PluginDescription describePlugin(File file) throws Exception
+    {
+        try ( JarFile jar = new JarFile( file ) )
+        {
+            JarEntry pdf = jar.getJarEntry( "bungee.yml" );
+            if ( pdf == null )
+            {
+                pdf = jar.getJarEntry( "plugin.yml" );
+            }
+            Preconditions.checkNotNull( pdf, "Plugin must have a plugin.yml or bungee.yml" );
+
+            try ( InputStream in = jar.getInputStream( pdf ) )
+            {
+                PluginDescription desc = yaml.loadAs( in, PluginDescription.class );
+                desc.setFile( file );
+                return desc;
+            }
+        }
+    }
+    // XWaterfall end
+
