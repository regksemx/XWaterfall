+# Configuration for the ban commands (gban, gtempban, gunban, gbanlist).
+# Colour codes using & are supported, and \n inserts a new line.
+# The following placeholders are replaced in the kick messages:
+#   {reason}  - the ban reason
+#   {expiry}  - remaining time for temporary bans
+#   {source}  - who issued the ban
+messages:
+  # Default reason used when a ban is issued without one.
+  default-reason: 'Banned by an operator.'
+  # Shown to a permanently banned player when they are denied entry.
+  permanent: '&cYou are banned from this network.\n&7Reason: &f{reason}'
+  # Shown to a temporarily banned player when they are denied entry.
+  temporary: '&cYou are temporarily banned from this network.\n&7Reason: &f{reason}\n&7Expires in: &f{expiry}'
