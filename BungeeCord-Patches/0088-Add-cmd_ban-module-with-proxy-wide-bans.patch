index 00000000..e2c8785d
--- /dev/null
+++ b/module/cmd-ban/src/main/java/net/md_5/bungee/module/cmd/ban/CommandBanList.java
@@ -0,0 +1,44 @@
+package net.md_5.bungee.module.cmd.ban;
+
+import java.util.Collection;
+import net.md_5.bungee.api.ChatColor;
+import net.md_5.bungee.api.CommandSender;
+import net.md_5.bungee.api.chat.TextComponent;
+import net.md_5.bungee.api.plugin.Command;
+
+public class CommandBanList extends Command
+{
+
+    private final BanManager bans;
+
+    public CommandBanList(BanManager bans)
+    {
+        super( "gbanlist", "bungeecord.command.banlist" );
+        this.bans = bans;
+    }
+
+    @Override
+    public void execute(CommandSender sender, String[] args)
+    {
+        Collection<BanEntry> active = bans.activeBans();
+        if ( active.isEmpty() )
+        {
+            sender.sendMessage( new TextComponent( ChatColor.GREEN + "There are no active bans." ) );
+            return;
+        }
+
+        sender.sendMessage( new TextComponent( ChatColor.GOLD + "Active bans (" + active.size() + "):" ) );
+        long now = System.currentTimeMillis();
+        for ( BanEntry entry : active )
+        {
+            String who = ( entry.name != null ) ? entry.name : entry.ip;
+            String duration = entry.isPermanent()
+                    ? ChatColor.RED + "permanent"
+                    : ChatColor.YELLOW + BanManager.formatDuration( entry.expires - now ) + " left";
+            sender.sendMessage( new TextComponent( ChatColor.GRAY + " - " + ChatColor.WHITE + who
+                    + ChatColor.GRAY + " (" + duration + ChatColor.GRAY + ") "
+                    + ChatColor.GRAY + "by " + ( entry.source == null ? "console" : entry.source )
+                    + ChatColor.GRAY + ": " + ChatColor.WHITE + ( entry.reason == null ? "" : entry.reason ) ) );
+        }
+    }
+}
