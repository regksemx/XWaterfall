+package net.md_5.bungee.module.cmd.ban;
+
+import net.md_5.bungee.api.plugin.Plugin;
+
+public class PluginBan extends Plugin
+{
+
+    @Override
+    public void onEnable()
+    {
+        BanManager bans = new BanManager( this );
+        getProxy().getPluginManager().registerCommand( this, new CommandBan( bans ) );
+        getProxy().getPluginManager().registerCommand( this, new CommandTempBan( bans ) );
+        getProxy().getPluginManager().registerCommand( this, new CommandUnban( bans ) );
+        getProxy().getPluginManager().registerCommand( this, new CommandBanList( bans ) );
+        getProxy().getPluginManager().registerListener( this, new BanListener( bans ) );
+    }
+}
