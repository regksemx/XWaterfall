+                xConfig.getInt("antibot.reconnect.window-ms", 30000),
+                xConfig.getInt("antibot.reconnect.verified-duration-ms", 600000));
+        net.regksem.xwaterfall.antibot.AntiBot.setMaxConnectionsPerIp(xConfig.getInt("antibot.max-connections-per-ip", 0));
