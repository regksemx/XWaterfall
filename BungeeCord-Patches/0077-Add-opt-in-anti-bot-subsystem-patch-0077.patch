diff --git a/proxy/src/main/resources/xwaterfall.yml b/proxy/src/main/resources/xwaterfall.yml
index 3fece123..d6fc2d7d 100644
--- a/proxy/src/main/resources/xwaterfall.yml
+++ b/proxy/src/main/resources/xwaterfall.yml
@@ -194,3 +194,54 @@ antiexploit:
   # legitimate packets such as Forge mod handshakes or login plugin payloads.
   # The Varint frame decoder already hard-caps frames at ~2 MB regardless.
   max-packet-bytes: 0
+
+# ---------------------------------------------------------------------------
+#  Anti-bot
+# ---------------------------------------------------------------------------
+# Proxy-level protection against join-floods / bot swarms. Disabled by default;
+# turn it on only if you actually get attacked, and tune the thresholds to your
+# traffic. Two checks (reconnect verification and direct-IP blocking) only
+# engage while an attack is detected, so normal players are never affected by
+# them; the per-IP cap and username filter apply whenever configured.
+antibot:
+  # Master switch for the whole subsystem.
+  enabled: false
+
+  # Logins per second that flip the proxy into "under attack" mode (which turns
+  # on the reconnect check and direct-IP blocking). -1 disables attack detection
+  # entirely, so those two checks never trigger.
+  attack-joins-per-second: 8
+
+  # Reconnect "firewall": while under attack, a new IP is kicked once and only
+  # allowed in after it reconnects. Bots almost never reconnect; real clients do.
+  reconnect:
+    # The reconnect must happen no sooner than this (ms) - filters out clients
+    # that instantly retry in a tight loop.
+    min-delay-ms: 1000
+    # ...and no later than this (ms) after the first attempt.
+    window-ms: 30000
+    # Once verified, an IP is trusted for this long (ms) without re-checking.
+    verified-duration-ms: 600000
+
+  # Max simultaneous online connections from a single IP. 0 disables the cap.
+  # Raise it if many of your players share an IP (NAT / another proxy in front).
+  max-connections-per-ip: 3
+
+  # While under attack, refuse connections made straight to the server IP
+  # (legitimate players connect through the configured domain).
+  block-direct-ip: true
+
+  # Regex every username must match, e.g. "^[A-Za-z0-9_]{3,16}$" to require
+  # vanilla-style names. Empty means accept any (valid) username.
