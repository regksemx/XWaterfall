diff --git a/proxy/src/main/java/net/regksem/xwaterfall/antibot/AntiBot.java b/proxy/src/main/java/net/regksem/xwaterfall/antibot/AntiBot.java
new file mode 100644
index 00000000..9b5d1376
--- /dev/null
+++ b/proxy/src/main/java/net/regksem/xwaterfall/antibot/AntiBot.java
@@ -0,0 +1,344 @@
+package net.regksem.xwaterfall.antibot;
+
+import com.google.common.net.InetAddresses;
+import java.net.InetSocketAddress;
+import java.net.SocketAddress;
+import java.util.Iterator;
+import java.util.Map;
+import java.util.concurrent.ConcurrentHashMap;
+import java.util.concurrent.atomic.AtomicInteger;
+import java.util.regex.Pattern;
+import net.md_5.bungee.api.chat.BaseComponent;
+import net.regksem.xwaterfall.motd.MotdManager;
+
+/**
+ * Proxy-level anti-bot facilities, integrated with {@code InitialHandler} and the
+ * connection lifecycle. Everything is static and lock-free; all state is held in
+ * concurrent maps and atomics so it can be touched from any Netty worker thread.
+ *
+ * <p>The whole subsystem is opt-in ({@link #enabled}) and defaults to off, so a
+ * stock configuration behaves exactly like upstream. Two of the checks
+ * (reconnect verification and direct-IP blocking) only engage while an attack is
+ * detected, so legitimate players are untouched during normal operation.
+ */
+public final class AntiBot
+{
+
+    private AntiBot()
+    {
+    }
+
+    // ---- configuration (pushed in from WaterfallConfiguration) ----
+    private static volatile boolean enabled = false;
+    private static volatile int attackJoinsPerSecond = -1; // -1 = attack mode never auto-engages
+    private static volatile long reconnectMinDelayMs = 1000L;
+    private static volatile long reconnectWindowMs = 30_000L;
+    private static volatile long verifiedDurationMs = 600_000L;
+    private static volatile int maxConnectionsPerIp = 0; // 0 = disabled
+    private static volatile boolean blockDirectIp = true; // only enforced under attack
+    private static volatile Pattern namePattern = null; // null = accept any name
+
+    // Messages are pre-rendered into chat components once at (re)load, so the
+    // colour pipeline never runs on the hot login path.
+    private static volatile BaseComponent msgReconnect = MotdManager.renderComponent( "&eVerifying your connection, please reconnect." );
+    private static volatile BaseComponent msgName = MotdManager.renderComponent( "&cYour username is not allowed on this server." );
+    private static volatile BaseComponent msgDirectIp = MotdManager.renderComponent( "&cPlease connect using the server address, not its IP." );
+    private static volatile BaseComponent msgIpLimit = MotdManager.renderComponent( "&cToo many connections from your IP address." );
+
+    // ---- rolling join-rate counter (1s buckets) ----
+    private static volatile long currentSecond = 0L;
+    private static final AtomicInteger currentCount = new AtomicInteger();
+    private static volatile int lastSecondCount = 0;
+
+    // ---- reconnect firewall state ----
+    private static final Map<String, Long> verified = new ConcurrentHashMap<>(); // ip -> expiry (ms)
+    private static final Map<String, Long> pending = new ConcurrentHashMap<>();   // ip -> first-seen (ms)
+
+    // ---- per-IP online connection counts ----
+    private static final Map<String, AtomicInteger> connectionCounts = new ConcurrentHashMap<>();
+
+    private static final int MAP_SWEEP_THRESHOLD = 10_000;
+
+    // ---- the kick outcomes of a login check ----
+    public enum Result
+    {
+        ALLOW, KICK_RECONNECT, KICK_NAME, KICK_DIRECT_IP, KICK_IP_LIMIT;
+    }
+
+    public static boolean isEnabled()
+    {
+        return enabled;
+    }
+
+    /**
+     * Records a login attempt and rolls the per-second counter. Call once at the
+     * very start of handling a login request.
+     */
+    public static void recordJoinAttempt()
+    {
+        if ( !enabled )
+        {
+            return;
+        }
+        long second = System.currentTimeMillis() / 1000L;
+        if ( second != currentSecond )
+        {
+            currentSecond = second;
+            lastSecondCount = currentCount.getAndSet( 0 );
+        }
+        currentCount.incrementAndGet();
+    }
+
+    /**
+     * @return true while the most recent completed second saw at least
+     *         {@code attack-joins-per-second} login attempts
+     */
+    public static boolean isUnderAttack()
+    {
+        if ( !enabled || attackJoinsPerSecond <= 0 )
+        {
+            return false;
+        }
+        long second = System.currentTimeMillis() / 1000L;
+        // If a whole second elapsed with no joins, the last bucket is stale: not under attack.
+        int recent = ( second - currentSecond <= 1L ) ? Math.max( lastSecondCount, currentCount.get() ) : 0;
+        return recent >= attackJoinsPerSecond;
+    }
+
+    /**
+     * Whether a handshake using the given virtual host should be refused. Only
+     * blocks raw-IP connections, and only while under attack.
+     */
+    public static boolean blocksDirectIp(String host)
+    {
+        if ( !enabled || !blockDirectIp || !isUnderAttack() || host == null )
+        {
+            return false;
+        }
+        String trimmed = host.trim();
+        return !trimmed.isEmpty() && InetAddresses.isInetAddress( trimmed );
+    }
+
+    /**
+     * Runs the per-login checks (name pattern, per-IP cap, reconnect firewall).
+     *
+     * @return {@link Result#ALLOW} to let the login proceed, otherwise the kick
+     *         reason to disconnect with
+     */
+    public static Result checkLogin(SocketAddress address, String name)
+    {
+        if ( !enabled )
+        {
+            return Result.ALLOW;
+        }
+        // Username pattern (always enforced when configured).
+        Pattern pattern = namePattern;
+        if ( pattern != null && ( name == null || !pattern.matcher( name ).matches() ) )
+        {
+            return Result.KICK_NAME;
+        }
+
+        String ip = ip( address );
+
+        // Per-IP concurrent connection cap (always enforced when configured).
+        if ( maxConnectionsPerIp > 0 )
+        {
+            AtomicInteger count = connectionCounts.get( ip );
+            if ( count != null && count.get() >= maxConnectionsPerIp )
+            {
+                return Result.KICK_IP_LIMIT;
+            }
+        }
+
+        // Reconnect firewall (only while under attack).
+        if ( isUnderAttack() )
+        {
+            long now = System.currentTimeMillis();
+            Long expiry = verified.get( ip );
+            if ( expiry != null && expiry > now )
+            {
+                return Result.ALLOW; // already verified within its window
+            }
+
+            Long firstSeen = pending.get( ip );
+            if ( firstSeen != null )
+            {
+                long age = now - firstSeen;
+                if ( age >= reconnectMinDelayMs && age <= reconnectWindowMs )
+                {
+                    // A genuine reconnect inside the window: promote to verified.
+                    verified.put( ip, now + verifiedDurationMs );
+                    pending.remove( ip );
+                    sweepIfNeeded( now );
+                    return Result.ALLOW;
+                }
+            }
+            // First contact (or too fast / too late): make them reconnect.
+            pending.put( ip, now );
+            sweepIfNeeded( now );
+            return Result.KICK_RECONNECT;
+        }
+
+        return Result.ALLOW;
+    }
+
+    /** Resolves the pre-rendered kick component for a non-ALLOW result. */
+    public static BaseComponent message(Result result)
+    {
+        switch ( result )
+        {
+            case KICK_NAME:
+                return msgName;
+            case KICK_DIRECT_IP:
+                return msgDirectIp;
+            case KICK_IP_LIMIT:
+                return msgIpLimit;
+            case KICK_RECONNECT:
+            default:
+                return msgReconnect;
+        }
+    }
+
+    public static BaseComponent directIpMessage()
+    {
+        return msgDirectIp;
+    }
+
+    // ---- per-IP connection accounting (called from BungeeCord add/remove) ----
+
+    public static void onConnectionOpened(SocketAddress address)
+    {
+        if ( !enabled || maxConnectionsPerIp <= 0 )
+        {
+            return;
+        }
+        connectionCounts.computeIfAbsent( ip( address ), k -> new AtomicInteger() ).incrementAndGet();
+    }
+
+    public static void onConnectionClosed(SocketAddress address)
+    {
+        if ( maxConnectionsPerIp <= 0 )
+        {
+            return;
+        }
+        String ip = ip( address );
+        AtomicInteger count = connectionCounts.get( ip );
+        if ( count != null && count.decrementAndGet() <= 0 )
+        {
+            connectionCounts.remove( ip, count );
+        }
+    }
+
+    // ---- helpers ----
+
+    private static String ip(SocketAddress address)
+    {
+        if ( address instanceof InetSocketAddress )
+        {
+            InetSocketAddress isa = (InetSocketAddress) address;
+            if ( isa.getAddress() != null )
+            {
+                return isa.getAddress().getHostAddress();
+            }
+        }
+        return String.valueOf( address );
+    }
+
+    /**
+     * Bounds the firewall maps under heavy attack by dropping entries that can no
+     * longer affect a decision. Only runs once a map grows past a threshold.
+     */
+    private static void sweepIfNeeded(long now)
+    {
+        if ( pending.size() > MAP_SWEEP_THRESHOLD )
+        {
+            for ( Iterator<Map.Entry<String, Long>> it = pending.entrySet().iterator(); it.hasNext(); )
+            {
+                if ( now - it.next().getValue() > reconnectWindowMs )
+                {
+                    it.remove();
+                }
+            }
+        }
+        if ( verified.size() > MAP_SWEEP_THRESHOLD )
+        {
+            for ( Iterator<Map.Entry<String, Long>> it = verified.entrySet().iterator(); it.hasNext(); )
+            {
+                if ( it.next().getValue() <= now )
+                {
+                    it.remove();
+                }
+            }
+        }
+    }
+
+    // ---- configuration setters (called from WaterfallConfiguration) ----
+
+    public static void setEnabled(boolean value)
+    {
+        enabled = value;
+    }
+
+    public static void setAttackJoinsPerSecond(int value)
+    {
+        attackJoinsPerSecond = value;
+    }
+
+    public static void setReconnect(long minDelayMs, long windowMs, long verifiedDurationMs)
+    {
+        AntiBot.reconnectMinDelayMs = Math.max( 0L, minDelayMs );
+        AntiBot.reconnectWindowMs = Math.max( AntiBot.reconnectMinDelayMs, windowMs );
+        AntiBot.verifiedDurationMs = Math.max( 0L, verifiedDurationMs );
+    }
+
+    public static void setMaxConnectionsPerIp(int value)
+    {
+        maxConnectionsPerIp = Math.max( 0, value );
+    }
+
+    public static void setBlockDirectIp(boolean value)
+    {
+        blockDirectIp = value;
+    }
+
+    public static void setNamePattern(String regex)
+    {
+        if ( regex == null || regex.isEmpty() )
+        {
+            namePattern = null;
+            return;
+        }
+        try
+        {
+            namePattern = Pattern.compile( regex );
+        } catch ( java.util.regex.PatternSyntaxException ex )
+        {
+            namePattern = null;
+        }
+    }
+
+    /**
+     * Re-renders the kick messages from raw templates into cached components
+     * (full MiniMessage / legacy / hex support). A null leaves the current
+     * value (i.e. the built-in default) in place.
+     */
+    public static void setMessages(String reconnect, String name, String directIp, String ipLimit)
+    {
+        if ( reconnect != null )
+        {
+            msgReconnect = MotdManager.renderComponent( reconnect );
+        }
+        if ( name != null )
+        {
+            msgName = MotdManager.renderComponent( name );
+        }
+        if ( directIp != null )
+        {
+            msgDirectIp = MotdManager.renderComponent( directIp );
+        }
+        if ( ipLimit != null )
+        {
+            msgIpLimit = MotdManager.renderComponent( ipLimit );
+        }
+    }
+}
