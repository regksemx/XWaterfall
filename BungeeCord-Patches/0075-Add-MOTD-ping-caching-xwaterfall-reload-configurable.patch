diff --git a/proxy/src/main/java/io/github/waterfallmc/waterfall/motd/MotdManager.java b/proxy/src/main/java/io/github/waterfallmc/waterfall/motd/MotdManager.java
index cc70d4bd..ea815ea8 100644
--- a/proxy/src/main/java/io/github/waterfallmc/waterfall/motd/MotdManager.java
+++ b/proxy/src/main/java/io/github/waterfallmc/waterfall/motd/MotdManager.java
@@ -38,6 +38,59 @@ public final class MotdManager
 
     private static final String LEGACY_CODE_CHARS = "0123456789abcdefklmnorx";
 
+    // XWaterfall start - cache the rendered MOTD component.
+    // Parsing the MiniMessage / legacy template and serializing it into a chat
+    // component is by far the most expensive part of answering a server-list
+    // ping, and the MOTD text changes very rarely. We therefore keep the last
+    // rendered component for a configurable window instead of rebuilding it on
+    // every ping. The live online / max counts shown in the player bar are still
+    // applied fresh per ping by the caller, so only the (rarely changing) MOTD
+    // text itself can lag by at most the cache window.
+    private static volatile BaseComponent cachedDescription;
+    private static volatile String cachedTemplate;
+    private static volatile long cacheExpiryNanos;
+
+    /**
+     * Like {@link #render(String, int, int)} but reuses the previously rendered
+     * component while it is still within the cache window and the template is
+     * unchanged.
+     *
+     * @param ttlMillis how long a rendered component may be reused, in
+     *                  milliseconds; {@code <= 0} disables caching and renders
+     *                  on every call
+     */
+    public static BaseComponent renderCached(String template, int online, int max, long ttlMillis)
+    {
+        if ( ttlMillis <= 0L )
+        {
+            return render( template, online, max );
+        }
+        long now = System.nanoTime();
+        BaseComponent cached = cachedDescription;
+        // now - cacheExpiryNanos < 0 is the overflow-safe "not yet expired" test.
+        if ( cached != null && now - cacheExpiryNanos < 0L && template.equals( cachedTemplate ) )
+        {
+            return cached;
+        }
+        BaseComponent rendered = render( template, online, max );
+        cachedDescription = rendered;
+        cachedTemplate = template;
+        cacheExpiryNanos = now + ttlMillis * 1_000_000L;
+        return rendered;
+    }
+
+    /**
+     * Drops the cached MOTD component so the next ping re-renders the template.
+     * Called when the MOTD configuration is (re)loaded.
+     */
+    public static void invalidate()
+    {
+        cachedDescription = null;
+        cachedTemplate = null;
+        cacheExpiryNanos = 0L;
+    }
+    // XWaterfall end
+
     /**
      * Renders a MOTD template into a chat component.
      *
