+  # How long (in seconds) a rendered custom motd is reused before it is parsed
+  # again. Parsing the motd template (MiniMessage / colors) is the most
+  # expensive part of answering a ping, so caching it sharply lowers CPU under
+  # ping spam. The live player count shown in the ping is always fresh; only the
+  # motd TEXT itself can lag by at most this many seconds, so if you embed
+  # {PLAYER_ONLINE} in the text it updates at most once per window.
+  # Use 0 to disable caching and render on every ping. Run "/xwaterfall motd
+  # reload" to apply motd changes immediately without waiting for the window.
+  cache-ttl: 30
+
   # Configuration for the custom motd.
   # The default format is MiniMessage, which allows RGB colors and gradients.
   # For more information: https://docs.advntr.dev/minimessage/index.html
@@ -115,6 +125,20 @@ compression:
 # CPU usage at the cost of very rare, slight added latency. Disabled by default.
 consolidate-flushes: false
 
+# ---------------------------------------------------------------------------
+#  Network event-loop threads
+# ---------------------------------------------------------------------------
+# Thread counts for the two Netty event-loop groups.
+# - boss-threads:   threads that only accept incoming connections. One is enough
+#                   for any realistic number of listeners; more just sit idle.
+# - worker-threads: threads that handle all packet I/O. 0 means "let Netty pick"
+#                   (2x available processors), which is the right default for
+#                   almost everyone. Set a fixed number only if you want to cap
+#                   or pin I/O threads.
+network:
+  boss-threads: 1
+  worker-threads: 0
+
 # ---------------------------------------------------------------------------
 #  Protocol gating
 # ---------------------------------------------------------------------------
