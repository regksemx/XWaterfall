diff --git a/proxy/src/main/java/net/md_5/bungee/command/CommandXWaterfall.java b/proxy/src/main/java/net/md_5/bungee/command/CommandXWaterfall.java
new file mode 100644
index 00000000..f478672a
--- /dev/null
+++ b/proxy/src/main/java/net/md_5/bungee/command/CommandXWaterfall.java
@@ -0,0 +1,42 @@
+package net.md_5.bungee.command;
+
+import net.md_5.bungee.BungeeCord;
+import net.md_5.bungee.api.ChatColor;
+import net.md_5.bungee.api.CommandSender;
+import net.md_5.bungee.api.plugin.Command;
+import net.md_5.bungee.conf.Configuration;
+import io.github.waterfallmc.waterfall.conf.WaterfallConfiguration;
+
+/**
+ * XWaterfall administration command. Currently exposes {@code motd reload},
+ * which re-reads the {@code motd.*} section of {@code xwaterfall.yml} and clears
+ * the cached server-list ping render without restarting listeners.
+ */
+public class CommandXWaterfall extends Command
+{
+
+    public CommandXWaterfall()
+    {
+        super( "xwaterfall", "bungeecord.command.xwaterfall", "xwf" );
+    }
+
+    @Override
+    public void execute(CommandSender sender, String[] args)
+    {
+        if ( args.length == 2 && args[0].equalsIgnoreCase( "motd" ) && args[1].equalsIgnoreCase( "reload" ) )
+        {
+            Configuration config = BungeeCord.getInstance().config;
+            if ( config instanceof WaterfallConfiguration )
+            {
+                ( (WaterfallConfiguration) config ).reloadMotd();
+                sender.sendMessage( ChatColor.GREEN + "MOTD reloaded from xwaterfall.yml and ping cache cleared." );
+            } else
+            {
+                sender.sendMessage( ChatColor.RED + "MOTD reload is unavailable on this configuration." );
+            }
+            return;
+        }
+
+        sender.sendMessage( ChatColor.RED + "Usage: /xwaterfall motd reload" );
+    }
+}
