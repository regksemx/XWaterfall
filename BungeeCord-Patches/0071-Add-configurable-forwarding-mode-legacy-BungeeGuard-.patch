@@ -0,0 +1,37 @@
+# ===========================================================================
+#  XWaterfall configuration
+# ---------------------------------------------------------------------------
+#  Settings specific to the XWaterfall fork. After editing, run the proxy
+#  command "reload" or restart the proxy for changes to take effect.
+#
+#  Note: keys that are missing from this file fall back to their built-in
+#  defaults, so it is safe to delete options you do not want to change.
+# ===========================================================================
+
+# ---------------------------------------------------------------------------
+#  Player info forwarding
+# ---------------------------------------------------------------------------
+# How player information (uuid, properties, ip address) is forwarded to the
+# backend servers. This only takes effect when "ip_forward" is enabled in
+# config.yml.
+#
+# Available modes:
+# - "BUNGEECORD_LEGACY": The proxy only sends uuid, properties and ip address.
+#                        Outdated and not secure, use it only if you are
+#                        absolutely sure that your backend servers cannot be
+#                        reached from the outside.
+# - "BUNGEEGUARD":       The proxy sends a secret along with the uuid, properties
+#                        and ip address, which is compared on the server.
+#                        This method is preferable and works on all versions of
+#                        the game.
+# - "VELOCITY_MODERN":   The proxy sends signed uuid, properties and ip address
+#                        data. This method is the most preferable, but it only
+#                        works on 1.13+ backend servers.
+forwarding_mode: BUNGEECORD_LEGACY
+
+# The secret key used for the BUNGEEGUARD and VELOCITY_MODERN forwarding modes.
+# - For VELOCITY_MODERN it must match the forwarding secret configured on the
+#   backend server (e.g. Paper's config/paper-global.yml -> proxies.velocity.secret).
+# - For BUNGEEGUARD it must match the token configured in the BungeeGuard plugin.
+# Keep it long and random. Ignored when forwarding_mode is BUNGEECORD_LEGACY.
+forwarding_secret: ''
