--- /dev/null
+++ b/proxy/src/main/java/net/md_5/bungee/conf/ForwardingMode.java
@@ -0,0 +1,51 @@
+package net.md_5.bungee.conf;
+
+/**
+ * The way the proxy forwards player information (ip, uuid, properties) to the
+ * backend servers.
+ */
+public enum ForwardingMode
+{
+
+    /**
+     * The proxy only sends uuid, properties and ip address. This is the classic
+     * BungeeCord forwarding format. Outdated and not secure: only use it if you
+     * are absolutely sure your backend servers cannot be reached from the
+     * outside.
+     */
+    BUNGEECORD_LEGACY,
+    /**
+     * The proxy sends a secret along with the uuid, properties and ip address,
+     * which is compared on the server by the BungeeGuard plugin. Works on all
+     * versions of the game.
+     */
+    BUNGEEGUARD,
+    /**
+     * The proxy sends signed uuid, properties and ip address data using the
+     * Velocity modern forwarding scheme. The most preferable method, but it only
+     * works on 1.13+ backend servers.
+     */
+    VELOCITY_MODERN;
+
+    /**
+     * Parses a forwarding mode from a configuration string, falling back to
+     * {@link #BUNGEECORD_LEGACY} when the value is missing or unrecognised.
+     *
+     * @param value the configured value
+     * @return the matching mode, never null
+     */
+    public static ForwardingMode fromString(String value)
+    {
+        if ( value != null )
+        {
+            for ( ForwardingMode mode : values() )
+            {
+                if ( mode.name().equalsIgnoreCase( value.trim() ) )
+                {
+                    return mode;
+                }
+            }
+        }
+        return BUNGEECORD_LEGACY;
+    }
+}
