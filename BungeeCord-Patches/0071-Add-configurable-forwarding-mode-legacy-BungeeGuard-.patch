     }
 
+    // XWaterfall start - Velocity modern forwarding
+    private static final String VELOCITY_PLAYER_INFO_CHANNEL = "velocity:player_info";
+    private static final int MODERN_FORWARDING_DEFAULT = 1;
+
     @Override
     public void handle(LoginPayloadRequest loginPayloadRequest)
     {
+        if ( BungeeCord.getInstance().config.isIpForward()
+                && BungeeCord.getInstance().config.getForwardingMode() == ForwardingMode.VELOCITY_MODERN
+                && VELOCITY_PLAYER_INFO_CHANNEL.equals( loginPayloadRequest.getChannel() ) )
+        {
+            ch.write( new LoginPayloadResponse( loginPayloadRequest.getId(), createVelocityForwardingData( loginPayloadRequest.getData() ) ) );
+            return;
+        }
         ch.write( new LoginPayloadResponse( loginPayloadRequest.getId(), null ) );
     }
 
+    private byte[] createVelocityForwardingData(byte[] requestData)
+    {
+        ByteBuf buf = Unpooled.buffer();
+        try
+        {
+            int requestedVersion = ( requestData != null && requestData.length >= 1 ) ? requestData[0] : MODERN_FORWARDING_DEFAULT;
+            // We only implement the keyless version 1 payload, which every backend accepts for players without a chat key.
+            int version = Math.min( requestedVersion, MODERN_FORWARDING_DEFAULT );
+
+            DefinedPacket.writeVarInt( version, buf );
+            DefinedPacket.writeString( AddressUtil.sanitizeAddress( user.getAddress() ), buf );
+            DefinedPacket.writeUUID( user.getUniqueId(), buf );
+            DefinedPacket.writeString( user.getName(), buf );
+
+            LoginResult profile = user.getPendingConnection().getLoginProfile();
+            DefinedPacket.writeProperties( ( profile != null ) ? profile.getProperties() : null, buf );
+
+            byte[] data = new byte[ buf.readableBytes() ];
+            buf.getBytes( buf.readerIndex(), data );
+
+            byte[] secret = BungeeCord.getInstance().config.getForwardingSecret().getBytes( StandardCharsets.UTF_8 );
+            Mac mac = Mac.getInstance( "HmacSHA256" );
+            mac.init( new SecretKeySpec( secret, "HmacSHA256" ) );
+            byte[] signature = mac.doFinal( data );
+
+            byte[] result = new byte[ signature.length + data.length ];
+            System.arraycopy( signature, 0, result, 0, signature.length );
+            System.arraycopy( data, 0, result, signature.length, data.length );
+            return result;
+        } catch ( Exception ex )
+        {
+            throw new RuntimeException( "Unable to create Velocity modern forwarding data", ex );
+        } finally
+        {
+            buf.release();
+        }
+    }
+    // XWaterfall end
+
     @Override
     public String toString()
     {
