--- /dev/null
+++ b/proxy/src/main/java/io/github/waterfallmc/waterfall/conf/XWaterfallConfig.java
@@ -0,0 +1,110 @@
+package io.github.waterfallmc.waterfall.conf;
+
+import java.io.File;
+import java.io.FileInputStream;
+import java.io.IOException;
+import java.io.InputStream;
+import java.nio.file.Files;
+import java.util.Collections;
+import java.util.Map;
+import java.util.logging.Level;
+import net.md_5.bungee.api.ProxyServer;
+import org.yaml.snakeyaml.Yaml;
+import org.yaml.snakeyaml.error.YAMLException;
+
+/**
+ * Loader for {@code xwaterfall.yml}, the XWaterfall-specific configuration file.
+ *
+ * <p>Unlike {@link net.md_5.bungee.conf.YamlConfig} this loader is strictly
+ * read-only: it never rewrites the file, so the comments shipped in the bundled
+ * default are preserved across restarts and version upgrades. When the file is
+ * absent the bundled default (with comments) is copied to disk; any keys missing
+ * from an existing file simply fall back to the supplied code defaults.
+ */
+public class XWaterfallConfig
+{
+
+    /**
+     * Name of both the on-disk file and the bundled classpath resource.
+     */
+    public static final String FILE_NAME = "xwaterfall.yml";
+
+    private final File file;
+    private Map<String, Object> config = Collections.emptyMap();
+
+    public XWaterfallConfig(File file)
+    {
+        this.file = file;
+    }
+
+    @SuppressWarnings("unchecked")
+    public void load()
+    {
+        // Write out the commented default if the file does not exist yet.
+        if ( !file.exists() )
+        {
+            try ( InputStream in = XWaterfallConfig.class.getClassLoader().getResourceAsStream( FILE_NAME ) )
+            {
+                if ( in != null )
+                {
+                    Files.copy( in, file.toPath() );
+                }
+            } catch ( IOException ex )
+            {
+                ProxyServer.getInstance().getLogger().log( Level.WARNING, "Could not write default " + FILE_NAME, ex );
+            }
+        }
+
+        if ( !file.exists() )
+        {
+            return; // Nothing to read; callers will use their defaults.
+        }
+
+        try ( InputStream is = new FileInputStream( file ) )
+        {
+            Map<String, Object> loaded = new Yaml().load( is );
+            if ( loaded != null )
+            {
+                config = loaded;
+            }
+        } catch ( IOException | YAMLException ex )
+        {
+            ProxyServer.getInstance().getLogger().log( Level.WARNING, "Could not load " + FILE_NAME + ", using defaults", ex );
+        }
+    }
+
+    @SuppressWarnings("unchecked")
+    private Object get(String path)
+    {
+        Map<String, Object> map = config;
+        String[] parts = path.split( "\\." );
+        for ( int i = 0; i < parts.length - 1; i++ )
+        {
+            Object sub = map.get( parts[i] );
+            if ( !( sub instanceof Map ) )
+            {
+                return null;
+            }
+            map = (Map<String, Object>) sub;
+        }
+        return map.get( parts[parts.length - 1] );
+    }
+
+    public String getString(String path, String def)
+    {
+        Object val = get( path );
+        return ( val != null ) ? val.toString() : def;
+    }
+
+    public boolean getBoolean(String path, boolean def)
+    {
+        Object val = get( path );
+        return ( val instanceof Boolean ) ? (Boolean) val : def;
+    }
+
+    public int getInt(String path, int def)
+    {
+        Object val = get( path );
+        return ( val instanceof Number ) ? ( (Number) val ).intValue() : def;
+    }
+}
