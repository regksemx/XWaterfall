+# ---------------------------------------------------------------------------
+#  Persistent storage
+# ---------------------------------------------------------------------------
+# Optional database used to persist data across restarts. The first consumer is
+# the anti-bot greylist: verified (trusted) IPs are remembered, so returning
+# players are not re-challenged after a proxy restart.
+#
+# The JDBC driver and the connection pool (HikariCP) are NOT bundled in the jar;
+# they are downloaded on first use into the "libraries" folder (the same way
+# plugin libraries are handled). An internet connection is therefore needed the
+# first time a database backend is enabled. The backend is chosen at startup and
+# is not affected by "/xwaterfall reload" - changing it requires a restart.
+storage:
+  # Backend type:
+  # - "memory":     no persistence; everything stays in RAM (default, no download)
+  # - "h2":         embedded file database (zero setup, good default for one proxy)
+  # - "sqlite":     embedded file database
+  # - "mysql":      external MySQL server
+  # - "mariadb":    external MariaDB server
+  # - "postgresql": external PostgreSQL server
+  type: memory
+
+  # Data file name for the embedded backends (h2 / sqlite). Created if missing.
+  file: "xwaterfall-data"
+
+  # Connection settings for the external backends (mysql / mariadb / postgresql).
+  host: "127.0.0.1"
+  port: 3306
+  database: "xwaterfall"
+  username: "root"
+  password: ""
+
+  # HikariCP connection pool size for external backends. Embedded backends use a
+  # single connection regardless.
+  pool-size: 6
+
+  # Maven repository the driver and HikariCP are downloaded from on first use.
+  # Point this at a mirror if you cannot reach Maven Central.
+  library-repository: "https://repo1.maven.org/maven2"
