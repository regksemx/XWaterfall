diff --git a/proxy/src/main/java/io/github/waterfallmc/waterfall/motd/AttackTracker.java b/proxy/src/main/java/io/github/waterfallmc/waterfall/motd/AttackTracker.java
new file mode 100644
index 00000000..911693c1
--- /dev/null
+++ b/proxy/src/main/java/io/github/waterfallmc/waterfall/motd/AttackTracker.java
@@ -0,0 +1,57 @@
+package io.github.waterfallmc.waterfall.motd;
+
+import java.util.concurrent.atomic.AtomicInteger;
+
+/**
+ * Lightweight global server-list-ping rate tracker used to decide whether the
+ * proxy is currently being hit by a ping flood. A ping attack typically comes
+ * from many different addresses, so this counts pings globally rather than
+ * per-IP (which is what {@link net.md_5.bungee.ConnectionThrottle} does).
+ */
+public final class AttackTracker
+{
+
+    private AttackTracker()
+    {
+    }
+
+    private static volatile long currentSecond;
+    private static final AtomicInteger currentCount = new AtomicInteger();
+    private static volatile int lastSecondCount;
+    // Disabled by default until a threshold is configured.
+    private static volatile int threshold = -1;
+
+    public static void setThreshold(int pingsPerSecond)
+    {
+        threshold = ( pingsPerSecond <= 0 ) ? -1 : pingsPerSecond;
+    }
+
+    /**
+     * Records a single server list ping. Cheap and thread-safe.
+     */
+    public static void recordPing()
+    {
+        long second = System.currentTimeMillis() / 1000L;
+        if ( second != currentSecond )
+        {
+            currentSecond = second;
+            lastSecondCount = currentCount.getAndSet( 0 );
+        }
+        currentCount.incrementAndGet();
+    }
+
+    /**
+     * @return true if the ping rate in the current or the previous second has
+     * reached the configured threshold.
+     */
+    public static boolean isUnderAttack()
+    {
+        if ( threshold < 0 )
+        {
+            return false;
+        }
+        long second = System.currentTimeMillis() / 1000L;
+        int previous = ( second - currentSecond <= 1 ) ? lastSecondCount : 0;
+        return currentCount.get() >= threshold || previous >= threshold;
+    }
+}
diff --git a/proxy/src/main/java/io/github/waterfallmc/waterfall/motd/MotdManager.java b/proxy/src/main/java/io/github/waterfallmc/waterfall/motd/MotdManager.java
new file mode 100644
index 00000000..cc70d4bd
--- /dev/null
+++ b/proxy/src/main/java/io/github/waterfallmc/waterfall/motd/MotdManager.java
@@ -0,0 +1,152 @@
+package io.github.waterfallmc.waterfall.motd;
+
+import java.awt.image.BufferedImage;
+import java.io.ByteArrayOutputStream;
+import java.io.File;
+import java.io.IOException;
+import java.util.Base64;
+import java.util.Iterator;
+import java.util.logging.Level;
+import javax.imageio.IIOImage;
+import javax.imageio.ImageIO;
+import javax.imageio.ImageWriteParam;
+import javax.imageio.ImageWriter;
+import javax.imageio.stream.ImageOutputStream;
+import net.kyori.adventure.text.Component;
+import net.kyori.adventure.text.minimessage.MiniMessage;
+import net.kyori.adventure.text.serializer.bungeecord.BungeeComponentSerializer;
+import net.md_5.bungee.api.Favicon;
+import net.md_5.bungee.api.ProxyServer;
+import net.md_5.bungee.api.chat.BaseComponent;
+import net.md_5.bungee.api.chat.TextComponent;
+import net.md_5.bungee.api.ChatColor;
+
+/**
+ * Renders the custom MOTD template and loads/compresses the ping favicon.
+ *
+ * <p>The template may use MiniMessage (RGB colors, gradients, ...) or legacy
+ * '&amp;' / section color codes including hex. The format is auto-detected: if
+ * the (placeholder-expanded) text contains legacy color codes it is parsed with
+ * the BungeeCord legacy parser, otherwise it is treated as MiniMessage.
+ */
+public final class MotdManager
+{
+
+    private MotdManager()
+    {
+    }
+
+    private static final String LEGACY_CODE_CHARS = "0123456789abcdefklmnorx";
+
+    /**
+     * Renders a MOTD template into a chat component.
+     *
+     * @param template the configured template
+     * @param online   the (already boosted) online count for {PLAYER_ONLINE}
+     * @param max       the max player count for {PLAYER_ONLINE_MAX}
+     * @return a chat component, never null
+     */
+    public static BaseComponent render(String template, int online, int max)
+    {
+        String text = template
+                .replace( "{PLAYER_ONLINE_MAX}", Integer.toString( max ) )
+                .replace( "{PLAYER_ONLINE}", Integer.toString( online ) )
+                .replace( "{NL}", "\n" );
+
+        try
+        {
+            if ( isLegacy( text ) )
+            {
+                return TextComponent.fromLegacy( ChatColor.translateAlternateColorCodes( '&', text ) );
+            }
+            Component component = MiniMessage.miniMessage().deserialize( text );
+            return new TextComponent( BungeeComponentSerializer.get().serialize( component ) );
+        } catch ( RuntimeException ex )
+        {
+            ProxyServer.getInstance().getLogger().log( Level.WARNING, "Could not parse custom MOTD, using it as plain text", ex );
+            return TextComponent.fromLegacy( text );
+        }
+    }
+
+    private static boolean isLegacy(String s)
+    {
+        if ( s.indexOf( ChatColor.COLOR_CHAR ) >= 0 )
+        {
+            return true;
+        }
+        for ( int i = 0; i + 1 < s.length(); i++ )
+        {
+            if ( s.charAt( i ) == '&' && LEGACY_CODE_CHARS.indexOf( Character.toLowerCase( s.charAt( i + 1 ) ) ) >= 0 )
+            {
+                return true;
+            }
+        }
+        return false;
+    }
+
+    /**
+     * Loads the favicon from the given path, optionally re-encoding it with a
+     * custom PNG compression level.
+     *
+     * @param path             path to a 64x64 PNG, or empty/null to disable
+     * @param compressionLevel 0.0..1.0 (closer to 0 = stronger), or -1 to keep
+     *                         the default encoding
+     * @return the favicon, or null when disabled or unreadable
+     */
+    public static Favicon loadFavicon(String path, double compressionLevel)
+    {
+        if ( path == null || path.isEmpty() )
+        {
+            return null;
+        }
+        File file = new File( path );
+        if ( !file.exists() )
+        {
+            return null;
+        }
+        try
+        {
+            BufferedImage image = ImageIO.read( file );
+            if ( image == null )
+            {
+                return null;
+            }
+            if ( image.getWidth() != 64 || image.getHeight() != 64 )
+            {
+                ProxyServer.getInstance().getLogger().log( Level.WARNING, "Server icon {0} must be exactly 64x64 pixels", path );
+                return null;
+            }
+            if ( compressionLevel < 0 )
+            {
+                return Favicon.create( image );
+            }
+            return Favicon.create( encode( image, compressionLevel ) );
+        } catch ( IOException | IllegalArgumentException ex )
+        {
+            ProxyServer.getInstance().getLogger().log( Level.WARNING, "Could not load server icon " + path, ex );
+            return null;
+        }
+    }
+
+    private static String encode(BufferedImage image, double compressionLevel) throws IOException
+    {
+        Iterator<ImageWriter> writers = ImageIO.getImageWritersByFormatName( "png" );
+        ImageWriter writer = writers.next();
+        ByteArrayOutputStream stream = new ByteArrayOutputStream();
+        try ( ImageOutputStream ios = ImageIO.createImageOutputStream( stream ) )
+        {
+            writer.setOutput( ios );
+            ImageWriteParam param = writer.getDefaultWriteParam();
+            if ( param.canWriteCompressed() )
+            {
+                param.setCompressionMode( ImageWriteParam.MODE_EXPLICIT );
+                param.setCompressionQuality( (float) Math.max( 0.0D, Math.min( 1.0D, compressionLevel ) ) );
+            }
+            writer.write( null, new IIOImage( image, null, null ), param );
+        } finally
+        {
+            writer.dispose();
+        }
+        return "data:image/png;base64," + Base64.getEncoder().encodeToString( stream.toByteArray() );
+    }
+}
