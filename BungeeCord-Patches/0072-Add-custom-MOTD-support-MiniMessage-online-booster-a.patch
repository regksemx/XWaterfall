@@ -296,11 +296,33 @@ public class InitialHandler extends PacketHandler implements PendingConnection
 
     private ServerPing getPingInfo(String motd, int protocol)
     {
+        // XWaterfall start - custom MOTD (online booster, custom player count, MiniMessage motd, attack favicon hiding)
+        net.md_5.bungee.conf.Configuration config = BungeeCord.getInstance().config;
+        int online = (int) Math.round( bungee.getOnlineCount() * config.getOnlineMultiplier() );
+        int max = ( config.getMotdMaxPlayers() > 0 ) ? config.getMotdMaxPlayers() : listener.getMaxPlayers();
+
+        net.md_5.bungee.api.chat.BaseComponent description;
+        String custom = config.getCustomMotd();
+        if ( custom != null && !custom.isEmpty() )
+        {
+            description = io.github.waterfallmc.waterfall.motd.MotdManager.render( custom, online, max );
+        } else
+        {
+            description = net.md_5.bungee.api.chat.TextComponent.fromLegacy( motd );
+        }
+
+        net.md_5.bungee.api.Favicon favicon = config.getFaviconObject();
+        if ( config.isHideFaviconOnAttack() && io.github.waterfallmc.waterfall.motd.AttackTracker.isUnderAttack() )
+        {
+            favicon = null;
+        }
+
         return new ServerPing(
                 new ServerPing.Protocol( bungee.getName() + " " + bungee.getGameVersion(), protocol ),
-                new ServerPing.Players( listener.getMaxPlayers(), bungee.getOnlineCount(), null ),
-                motd, BungeeCord.getInstance().config.getFaviconObject()
+                new ServerPing.Players( max, online, null ),
+                description, favicon
         );
+        // XWaterfall end
     }
 
     @Override
@@ -309,9 +331,13 @@ public class InitialHandler extends PacketHandler implements PendingConnection
         Preconditions.checkState( thisState == State.STATUS, "Not expecting STATUS" );
         thisState = null; // don't accept multiple status requests and set state to ping in async event callback
 
+        io.github.waterfallmc.waterfall.motd.AttackTracker.recordPing(); // XWaterfall - ping attack detection
+
         ServerInfo forced = AbstractReconnectHandler.getForcedHost( this );
         final String motd = ( forced != null ) ? forced.getMotd() : listener.getMotd();
-        final int protocol = ( ProtocolConstants.SUPPORTED_VERSION_IDS.contains( handshake.getProtocolVersion() ) ) ? handshake.getProtocolVersion() : bungee.getProtocolVersion();
