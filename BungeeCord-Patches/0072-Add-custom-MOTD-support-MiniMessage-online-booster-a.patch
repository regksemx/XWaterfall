diff --git a/proxy/src/main/resources/xwaterfall.yml b/proxy/src/main/resources/xwaterfall.yml
index 5f8afad8..54467f9f 100644
--- a/proxy/src/main/resources/xwaterfall.yml
+++ b/proxy/src/main/resources/xwaterfall.yml
@@ -35,3 +35,50 @@ forwarding_mode: BUNGEECORD_LEGACY
 # - For BUNGEEGUARD it must match the token configured in the BungeeGuard plugin.
 # Keep it long and random. Ignored when forwarding_mode is BUNGEECORD_LEGACY.
 forwarding_secret: ''
+
+# ---------------------------------------------------------------------------
+#  Server list ping (MOTD)
+# ---------------------------------------------------------------------------
+motd:
+  # What game protocol should be reported in the motd?
+  # -1 - the connecting client's own protocol is used, so the server is never
+  #      shown as outdated for any supported version.
+  # Any other number forces that exact protocol id.
+  protocol-version: -1
+
+  # Should the favicon be hidden when a ping attack is detected?
+  # Helps to save traffic, because the StatusResponse packet is never compressed,
+  # which means it can weigh at least 8 kilobytes.
+  hide-favicon-on-attack: true
+
+  # How many server list pings per second are treated as an attack.
+  # Used together with hide-favicon-on-attack. Set to -1 to disable detection.
+  attack-pings-per-second: 60
+
+  # The path to the favicon. Disabled if empty. Must be a 64x64 PNG.
+  favicon-path: "server-icon.png"
+
+  # How hard to compress the favicon?
+  # The closer the value is to zero, the stronger the compression.
+  # Fractional values from 0.0 to 1.0 are allowed. -1 - to disable.
+  favicon-compression-level: 0.0
+
+  # Online count booster. The online shown in the ping is computed as
+  # round(real online * multiplier). 1.0 keeps the real value.
+  online-multiplier: 1.0
+
+  # Configuration for the custom motd.
+  # The default format is MiniMessage, which allows RGB colors and gradients.
+  # For more information: https://docs.advntr.dev/minimessage/index.html
+  # Legacy '&' / section color codes and hex (&x&R&R&G&G&B&B / section x ...) are
+  # also supported and auto-detected. To create a new line use the placeholder {NL}
+  custom:
+    # Standard motd message. Leave empty to use the listener motd from config.yml.
+    #
+    # Available placeholders:
+    # - {PLAYER_ONLINE}:     Current online players (after the multiplier).
+    # - {PLAYER_ONLINE_MAX}: Max online players (the max-players value below).
+    motd: "<gradient:#FCA005:#FFCF00><bold>XWaterfall</bold></gradient> <dark_gray>▶ <gray>powered proxy{NL}<gray>Welcome, <white>{PLAYER_ONLINE}<gray>/<white>{PLAYER_ONLINE_MAX} <gray>online"
+
+    # Maximum number of players shown in the ping.
+    max-players: 100
