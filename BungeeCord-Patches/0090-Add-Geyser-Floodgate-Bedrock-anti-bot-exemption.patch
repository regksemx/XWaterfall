+  # Geyser / Floodgate (Bedrock) compatibility. Geyser proxies Bedrock players to
+  # the proxy as ordinary Java connections, so the connection checks above
+  # (username pattern, per-IP cap, direct-IP block, reconnect & liveness checks)
+  # as well as protocol gating and antiexploit.max-packet-bytes would wrongly
+  # reject them. When "exempt" is on, connections identified as Geyser/Floodgate
+  # skip those gates - they remain subject to the in-game limits (chat/command
+  # spam and tab-complete length). Detection is automatic: Geyser's local
+  # pipeline handler and Floodgate's channel marker. If you run a *standalone*
+  # Geyser (a separate process, not a plugin on this proxy), add its source IP to
+  # trusted-addresses so its players are recognised too.
+  bedrock:
+    exempt: true
+    trusted-addresses: []
