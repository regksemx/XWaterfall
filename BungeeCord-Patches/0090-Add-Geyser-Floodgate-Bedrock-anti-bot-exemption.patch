diff --git a/proxy/src/main/java/net/regksem/xwaterfall/antibot/BedrockDetector.java b/proxy/src/main/java/net/regksem/xwaterfall/antibot/BedrockDetector.java
new file mode 100644
index 00000000..69f4d098
--- /dev/null
+++ b/proxy/src/main/java/net/regksem/xwaterfall/antibot/BedrockDetector.java
@@ -0,0 +1,243 @@
+package net.regksem.xwaterfall.antibot;
+
+import com.google.common.collect.Multimap;
+import io.netty.channel.Channel;
+import io.netty.util.AttributeKey;
+import java.lang.reflect.Field;
+import java.net.InetAddress;
+import java.net.InetSocketAddress;
+import java.net.SocketAddress;
+import java.util.Collection;
+import java.util.Collections;
+import java.util.HashSet;
+import java.util.Set;
+import net.md_5.bungee.BungeeCord;
+import net.md_5.bungee.api.plugin.Listener;
+import net.md_5.bungee.api.plugin.Plugin;
+import net.md_5.bungee.api.plugin.PluginManager;
+
+/**
+ * Detects Bedrock Edition players arriving through Geyser/Floodgate so the
+ * anti-bot and anti-exploit gates can exempt them.
+ *
+ * <p>Geyser proxies a Bedrock client to the proxy as an ordinary Java
+ * connection, so the connection-level heuristics (username shape, per-IP caps,
+ * raw-IP blocking, reconnect / liveness verification, protocol gating, single
+ * packet size caps) all produce false positives for Bedrock players. The
+ * in-game limits (chat / command spam, tab-complete length) are left in place;
+ * those engage on actual behaviour and are harmless to Bedrock players.
+ *
+ * <p>Everything here is best-effort and reflection-based: the proxy core never
+ * compiles against Geyser or Floodgate. If those plugins are absent, or their
+ * internals change, detection simply degrades to "not bedrock" and the gates
+ * apply as usual. The whole thing is gated by {@link #exempt}; when off the
+ * detector always returns {@code false}.
+ *
+ * <p>Two signals are used, mirroring how Geyser/Floodgate tag their channels:
+ * <ul>
+ *   <li>Geyser-BungeeCord installs a pipeline handler named
+ *       {@value #GEYSER_COMPRESSION_DISABLER} on the local connections it opens
+ *       for Bedrock players - a reflection-free, reliable marker.</li>
+ *   <li>Floodgate stores a {@code FloodgatePlayer} under a private
+ *       {@link AttributeKey} on the channel once it has identified a Bedrock
+ *       player; the key is read once via reflection and cached.</li>
+ * </ul>
+ * Plus an optional operator-supplied {@link #trustedAddresses} list for the
+ * source address of a standalone Geyser instance.
+ */
+public final class BedrockDetector
+{
+
+    private BedrockDetector()
+    {
+    }
+
+    /** Pipeline handler Geyser-BungeeCord adds to the local connections it opens. */
+    private static final String GEYSER_COMPRESSION_DISABLER = "geyser-compression-disabler";
+    /** Private field on Floodgate's Bungee listener holding the channel marker key. */
+    private static final String FLOODGATE_ATTRIBUTE_FIELD = "playerAttribute";
+
+    private static volatile boolean exempt = true;
+    private static volatile Set<String> trustedAddresses = Collections.emptySet();
+
+    // Lazily-resolved Floodgate channel attribute key (resolved on first use).
+    private static volatile AttributeKey<?> floodgateKey;
+    private static volatile boolean floodgateResolved; // true once resolution has been attempted
+
+    public static boolean isExempt()
+    {
+        return exempt;
+    }
+
+    public static void setExempt(boolean value)
+    {
+        exempt = value;
+    }
+
+    public static void setTrustedAddresses(Collection<String> addresses)
+    {
+        Set<String> set = new HashSet<>();
+        if ( addresses != null )
+        {
+            for ( String address : addresses )
+            {
+                if ( address != null && !address.trim().isEmpty() )
+                {
+                    set.add( address.trim() );
+                }
+            }
+        }
+        trustedAddresses = set;
+    }
+
+    /**
+     * Re-arms lazy Floodgate resolution. Called when the anti-bot config is
+     * (re)loaded so a Floodgate plugin enabled/replaced at runtime is picked up
+     * on the next connection.
+     */
+    public static void resetDetection()
+    {
+        floodgateResolved = false;
+        floodgateKey = null;
+    }
+
+    /**
+     * @return true if this connection belongs to a Geyser/Floodgate (Bedrock)
+     *         player and should bypass the connection-gating checks
+     */
+    public static boolean isBedrock(Channel channel)
+    {
+        if ( !exempt || channel == null )
+        {
+            return false;
+        }
+        if ( isGeyserLocal( channel ) )
+        {
+            return true;
+        }
+        if ( isFloodgate( channel ) )
+        {
+            return true;
+        }
+        return !trustedAddresses.isEmpty() && isTrustedAddress( channel.remoteAddress() );
+    }
+
+    private static boolean isGeyserLocal(Channel channel)
+    {
+        try
+        {
+            return channel.pipeline().get( GEYSER_COMPRESSION_DISABLER ) != null;
+        } catch ( Exception ex )
+        {
+            return false;
+        }
+    }
+
+    private static boolean isFloodgate(Channel channel)
+    {
+        AttributeKey<?> key = floodgateKey;
+        if ( key == null )
+        {
+            if ( floodgateResolved )
+            {
+                return false;
+            }
+            key = resolveFloodgateKey();
+            if ( key == null )
+            {
+                return false;
+            }
+        }
+        try
+        {
+            return channel.attr( key ).get() != null;
+        } catch ( Exception ex )
+        {
+            return false;
+        }
+    }
+
+    private static boolean isTrustedAddress(SocketAddress address)
+    {
+        if ( address instanceof InetSocketAddress )
+        {
+            InetAddress addr = ( (InetSocketAddress) address ).getAddress();
+            if ( addr != null )
+            {
+                return trustedAddresses.contains( addr.getHostAddress() );
+            }
+        }
+        return false;
+    }
+
+    /**
+     * Reads the private {@code playerAttribute} {@link AttributeKey} from
+     * Floodgate's Bungee listener - the key Floodgate sets on a channel once it
+     * has identified a Bedrock player. Resolution is attempted at most once per
+     * config (re)load; any failure leaves the key null and detection falls back
+     * to the Geyser handler / trusted-address list.
+     */
+    private static synchronized AttributeKey<?> resolveFloodgateKey()
+    {
+        if ( floodgateResolved )
+        {
+            return floodgateKey;
+        }
+        floodgateResolved = true;
+        try
+        {
+            PluginManager pluginManager = BungeeCord.getInstance().getPluginManager();
+            Plugin floodgate = pluginManager.getPlugin( "floodgate" );
+            if ( floodgate == null )
+            {
+                return null;
+            }
+            for ( Listener listener : listenersOf( pluginManager, floodgate ) )
+            {
+                Field field = findField( listener.getClass(), FLOODGATE_ATTRIBUTE_FIELD );
+                if ( field == null )
+                {
+                    continue;
+                }
+                field.setAccessible( true );
+                Object value = field.get( listener );
+                if ( value instanceof AttributeKey )
+                {
+                    floodgateKey = (AttributeKey<?>) value;
+                    BungeeCord.getInstance().getLogger().info(
+                            "[XWaterfall] Floodgate detected; Bedrock players will bypass anti-bot connection checks." );
+                    return floodgateKey;
+                }
+            }
+        } catch ( Throwable ignored )
+        {
+            // Best-effort: any failure leaves floodgateKey null (no false positives).
+        }
+        return null;
+    }
+
+    /** Reads the registered listeners for a plugin via the private PluginManager map. */
+    @SuppressWarnings("unchecked")
+    private static Collection<Listener> listenersOf(PluginManager pluginManager, Plugin plugin) throws Exception
+    {
+        Field field = PluginManager.class.getDeclaredField( "listenersByPlugin" );
+        field.setAccessible( true );
+        Multimap<Plugin, Listener> map = (Multimap<Plugin, Listener>) field.get( pluginManager );
+        return map.get( plugin );
+    }
+
+    private static Field findField(Class<?> type, String name)
+    {
+        for ( Class<?> c = type; c != null && c != Object.class; c = c.getSuperclass() )
+        {
+            try
+            {
+                return c.getDeclaredField( name );
+            } catch ( NoSuchFieldException ignored )
+            {
+                // walk up the hierarchy
+            }
+        }
+        return null;
+    }
+}
