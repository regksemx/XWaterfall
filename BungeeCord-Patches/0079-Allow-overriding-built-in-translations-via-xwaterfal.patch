From 442285ce0a3ab0241039eb35963163bda3bd0477 Mon Sep 17 00:00:00 2001
From: regksem <regksem@tuta.io>
Date: Fri, 19 Jun 2026 22:07:30 +0300
Subject: [PATCH] Allow overriding built-in translations via xwaterfall.yml
 messages: (patch 0079)

A new messages: section maps any BungeeCord translation key (proxy_full,
outdated_client, name_invalid, ...) to a template rendered through the shared
MiniMessage / legacy / hex pipeline. Overrides are rendered once into cached
MessageFormats and overlaid in BungeeCord.reloadMessages after the defaults,
preserving positional args. Reloadable via /xwaterfall messages reload, and a
new /xwaterfall reload refreshes motd + anti-bot + messages together.

diff --git a/proxy/src/main/java/io/github/waterfallmc/waterfall/conf/WaterfallConfiguration.java b/proxy/src/main/java/io/github/waterfallmc/waterfall/conf/WaterfallConfiguration.java
index 47ffb187..29717120 100644
--- a/proxy/src/main/java/io/github/waterfallmc/waterfall/conf/WaterfallConfiguration.java
+++ b/proxy/src/main/java/io/github/waterfallmc/waterfall/conf/WaterfallConfiguration.java
@@ -123,6 +123,28 @@ public class WaterfallConfiguration extends Configuration {
 
         // Anti-bot
         applyAntiBot(xConfig);
+
+        // Message overrides for built-in translations
+        applyMessageOverrides(xConfig);
+    }
+
+    /**
+     * Loads the {@code messages:} overrides and rebuilds the translation table so
+     * they take effect (and are re-rendered through the colour pipeline).
+     */
+    private void applyMessageOverrides(XWaterfallConfig xConfig) {
+        net.regksem.xwaterfall.message.MessageOverrides.load(xConfig.getStringMap("messages"));
+        net.md_5.bungee.BungeeCord.getInstance().reloadMessages();
+    }
+
+    /**
+     * Re-reads only the {@code messages:} section and rebuilds the translation
+     * table. Backs {@code /xwaterfall messages reload}.
+     */
+    public void reloadMessageOverrides() {
+        XWaterfallConfig xConfig = new XWaterfallConfig(new File(XWaterfallConfig.FILE_NAME));
+        xConfig.load();
+        applyMessageOverrides(xConfig);
     }
 
     /**
