diff --git a/proxy/src/main/java/net/regksem/xwaterfall/conf/XWaterfallConfig.java b/proxy/src/main/java/net/regksem/xwaterfall/conf/XWaterfallConfig.java
index 41a4007e..c9011b23 100644
--- a/proxy/src/main/java/net/regksem/xwaterfall/conf/XWaterfallConfig.java
+++ b/proxy/src/main/java/net/regksem/xwaterfall/conf/XWaterfallConfig.java
@@ -135,4 +135,27 @@ public class XWaterfallConfig
         }
         return result;
     }
+
+    /**
+     * Reads a flat mapping at the given path as string -&gt; string. Returns an
+     * empty map when the key is missing or not a mapping. Keys and values are
+     * coerced to strings; null values are skipped.
+     */
+    public java.util.Map<String, String> getStringMap(String path)
+    {
+        Object val = get( path );
+        if ( !( val instanceof java.util.Map ) )
+        {
+            return java.util.Collections.emptyMap();
+        }
+        java.util.Map<String, String> result = new java.util.LinkedHashMap<>();
+        for ( java.util.Map.Entry<?, ?> entry : ( (java.util.Map<?, ?>) val ).entrySet() )
+        {
+            if ( entry.getKey() != null && entry.getValue() != null )
+            {
+                result.put( entry.getKey().toString(), entry.getValue().toString() );
+            }
+        }
+        return result;
+    }
 }
diff --git a/proxy/src/main/java/net/regksem/xwaterfall/message/MessageOverrides.java b/proxy/src/main/java/net/regksem/xwaterfall/message/MessageOverrides.java
new file mode 100644
index 00000000..77b060d5
--- /dev/null
+++ b/proxy/src/main/java/net/regksem/xwaterfall/message/MessageOverrides.java
@@ -0,0 +1,73 @@
+package net.regksem.xwaterfall.message;
+
+import java.text.Format;
+import java.text.MessageFormat;
+import java.util.Collections;
+import java.util.LinkedHashMap;
+import java.util.Map;
+import java.util.logging.Level;
+import net.md_5.bungee.api.ProxyServer;
+import net.md_5.bungee.api.chat.BaseComponent;
+import net.regksem.xwaterfall.motd.MotdManager;
+
+/**
+ * Lets {@code xwaterfall.yml} override the built-in BungeeCord translation
+ * messages (the keys in {@code messages.properties}: {@code proxy_full},
+ * {@code outdated_client}, {@code name_invalid}, ...) and render them through the
+ * shared MiniMessage / legacy / hex pipeline.
+ *
+ * <p>Each override is rendered once into a legacy-section string and stored as a
+ * {@link MessageFormat}, so the colour parse happens at (re)load time, not per
+ * lookup. Positional arguments such as {@code {0}} are preserved and substituted
+ * by {@code getTranslation} exactly like the stock messages. The rendered string
+ * round-trips back into a coloured component wherever the translation is shown
+ * via {@code fromLegacy} (kick screens, etc.).
+ */
+public final class MessageOverrides
+{
+
+    private MessageOverrides()
+    {
+    }
+
+    private static volatile Map<String, String> templates = Collections.emptyMap();
+
+    /** Loads the raw key -&gt; template map (typically the {@code messages:} section). */
+    public static void load(Map<String, String> raw)
+    {
+        Map<String, String> copy = new LinkedHashMap<>();
+        if ( raw != null )
+        {
+            for ( Map.Entry<String, String> entry : raw.entrySet() )
+            {
+                if ( entry.getKey() != null && entry.getValue() != null && !entry.getValue().isEmpty() )
+                {
+                    copy.put( entry.getKey(), entry.getValue() );
+                }
+            }
+        }
+        templates = copy;
+    }
+
+    /**
+     * Overlays the loaded overrides onto a translation format map (called from
+     * {@code BungeeCord.reloadMessages} after the defaults are populated). A
+     * template that fails to render or compile is skipped so the stock message
+     * stays in place.
+     */
+    public static void apply(Map<String, Format> formats)
+    {
+        for ( Map.Entry<String, String> entry : templates.entrySet() )
+        {
+            try
+            {
+                BaseComponent component = MotdManager.renderComponent( entry.getValue() );
+                formats.put( entry.getKey(), new MessageFormat( component.toLegacyText() ) );
+            } catch ( RuntimeException ex )
+            {
+                ProxyServer.getInstance().getLogger().log( Level.WARNING,
+                        "Skipping invalid message override for '" + entry.getKey() + "'", ex );
+            }
+        }
+    }
+}
