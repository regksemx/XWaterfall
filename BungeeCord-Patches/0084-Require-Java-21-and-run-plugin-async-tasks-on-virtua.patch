diff --git a/proxy/src/main/java/io/github/waterfallmc/waterfall/conf/WaterfallConfiguration.java b/proxy/src/main/java/io/github/waterfallmc/waterfall/conf/WaterfallConfiguration.java
index 2a5dc991..fa42d71a 100644
--- a/proxy/src/main/java/io/github/waterfallmc/waterfall/conf/WaterfallConfiguration.java
+++ b/proxy/src/main/java/io/github/waterfallmc/waterfall/conf/WaterfallConfiguration.java
@@ -104,6 +104,11 @@ public class WaterfallConfiguration extends Configuration {
         bossThreads = Math.max(1, xConfig.getInt("network.boss-threads", bossThreads));
         workerThreads = Math.max(0, xConfig.getInt("network.worker-threads", workerThreads));
 
+        // Virtual threads for plugin async tasks. Bound when a plugin first
+        // creates its executor, so changing this requires a restart for already
+        // started plugins.
+        useVirtualThreads = xConfig.getBoolean("use-virtual-threads", useVirtualThreads);
+
         // Protocol gating, connection-error hiding and anti-spam caps (runtime-reloadable)
         applyAntiExploit(xConfig);
 
diff --git a/proxy/src/main/java/net/md_5/bungee/conf/Configuration.java b/proxy/src/main/java/net/md_5/bungee/conf/Configuration.java
index cec89526..db5e94bd 100644
--- a/proxy/src/main/java/net/md_5/bungee/conf/Configuration.java
+++ b/proxy/src/main/java/net/md_5/bungee/conf/Configuration.java
@@ -138,6 +138,15 @@ public abstract class Configuration implements ProxyConfig
      */
     protected boolean consolidateFlushes = false;
     // XWaterfall end
+    // XWaterfall start - virtual threads for plugin async tasks (loaded from xwaterfall.yml)
+    /**
+     * When enabled, each plugin's async task executor uses a virtual-thread-per-task
+     * executor (Java 21+) instead of a cached pool of platform threads. Plugin
+     * async work is usually blocking I/O, which virtual threads handle far more
+     * cheaply at high concurrency. Enabled by default.
+     */
+    protected boolean useVirtualThreads = true;
+    // XWaterfall end
     // XWaterfall start - configurable Netty event-loop thread counts (loaded from xwaterfall.yml)
     /**
      * Number of threads in the boss group, which only accepts new connections.
diff --git a/proxy/src/main/resources/xwaterfall.yml b/proxy/src/main/resources/xwaterfall.yml
index d61644c5..8279edb6 100644
--- a/proxy/src/main/resources/xwaterfall.yml
+++ b/proxy/src/main/resources/xwaterfall.yml
@@ -139,6 +139,19 @@ network:
   boss-threads: 1
   worker-threads: 0
 
+# ---------------------------------------------------------------------------
+#  Virtual threads (Java 21+)
+# ---------------------------------------------------------------------------
+# Run each plugin's async task executor on a virtual-thread-per-task executor
+# instead of a cached pool of platform threads. Plugin async tasks are usually
+# blocking I/O (database, HTTP, Redis); virtual threads carry many such tasks at
+# once without the overhead and thread-exhaustion of a growing platform-thread
+# pool. This does NOT affect the proxy's own networking, which is already
+# non-blocking (Netty), so the gain is proportional to how much blocking async
+# work your plugins do. Bound when a plugin first starts, so a change takes
+# effect on the next restart. Leave enabled unless a plugin misbehaves under it.
+use-virtual-threads: true
+
 # ---------------------------------------------------------------------------
 #  Protocol gating
 # ---------------------------------------------------------------------------
