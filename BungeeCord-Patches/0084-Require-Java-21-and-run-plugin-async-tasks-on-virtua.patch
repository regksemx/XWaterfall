From 7b7b3d80529f210c4371ff841101fb4758cf3754 Mon Sep 17 00:00:00 2001
From: regksem <regksem@tuta.io>
Date: Sat, 20 Jun 2026 01:00:16 +0300
Subject: [PATCH] Require Java 21 and run plugin async tasks on virtual threads

Bump the compiler target to Java 21 and the bootstrap version gate to the
matching class-file version, and route each plugin's async task executor to a
virtual-thread-per-task executor (configurable via use-virtual-threads in
xwaterfall.yml, default on). Plugin async work is typically blocking I/O, which
virtual threads carry far more cheaply at high concurrency than a growing pool
of platform threads. The proxy's own networking is unchanged (already
non-blocking Netty).

diff --git a/api/src/main/java/net/md_5/bungee/api/ProxyConfig.java b/api/src/main/java/net/md_5/bungee/api/ProxyConfig.java
index 469fe0e1..b370e9fa 100644
--- a/api/src/main/java/net/md_5/bungee/api/ProxyConfig.java
+++ b/api/src/main/java/net/md_5/bungee/api/ProxyConfig.java
@@ -275,4 +275,17 @@ public interface ProxyConfig
      * @return the configured limit
      */
     int getPluginChannelNameLimit();
+
+    // XWaterfall start
+    /**
+     * Whether plugin async tasks should run on virtual threads (Java 21+)
+     * instead of a cached pool of platform threads.
+     *
+     * @return {@code true} if virtual threads are used for plugin async work
+     */
+    default boolean isUseVirtualThreads()
+    {
+        return true;
+    }
+    // XWaterfall end
 }
diff --git a/api/src/main/java/net/md_5/bungee/api/plugin/Plugin.java b/api/src/main/java/net/md_5/bungee/api/plugin/Plugin.java
index faa06a92..4c56ae55 100644
--- a/api/src/main/java/net/md_5/bungee/api/plugin/Plugin.java
+++ b/api/src/main/java/net/md_5/bungee/api/plugin/Plugin.java
@@ -129,8 +129,24 @@ public class Plugin
         if ( service == null )
         {
             String name = ( getDescription() == null ) ? "unknown" : getDescription().getName();
-            service = Executors.newCachedThreadPool( new ThreadFactoryBuilder().setNameFormat( name + " Pool Thread #%1$d" )
-                    .setThreadFactory( new GroupedThreadFactory( this, name ) ).build() );
+            // XWaterfall start - use a virtual-thread-per-task executor for plugin
+            // async work when enabled. Plugin async tasks are typically blocking
+            // (JDBC, HTTP, Redis); virtual threads let those scale without an
+            // ever-growing pool of pinned platform threads. Falls back to the
+            // classic cached pool when disabled (use-virtual-threads: false) or
+            // when the config is not available yet.
+            ProxyServer proxy = ProxyServer.getInstance();
+            boolean virtual = ( proxy == null || proxy.getConfig() == null ) || proxy.getConfig().isUseVirtualThreads();
+            if ( virtual )
+            {
+                service = Executors.newThreadPerTaskExecutor( Thread.ofVirtual()
+                        .name( name + " Virtual Pool Thread #", 1 ).factory() );
+            } else
+            {
+                service = Executors.newCachedThreadPool( new ThreadFactoryBuilder().setNameFormat( name + " Pool Thread #%1$d" )
+                        .setThreadFactory( new GroupedThreadFactory( this, name ) ).build() );
+            }
+            // XWaterfall end
         }
         return service;
     }
diff --git a/bootstrap/src/main/java/net/md_5/bungee/Bootstrap.java b/bootstrap/src/main/java/net/md_5/bungee/Bootstrap.java
index cbb740c9..143463c0 100644
--- a/bootstrap/src/main/java/net/md_5/bungee/Bootstrap.java
+++ b/bootstrap/src/main/java/net/md_5/bungee/Bootstrap.java
@@ -5,9 +5,9 @@ public class Bootstrap
 
     public static void main(String[] args) throws Exception
     {
-        if ( Float.parseFloat( System.getProperty( "java.class.version" ) ) < 61.0 )
+        if ( Float.parseFloat( System.getProperty( "java.class.version" ) ) < 65.0 )
         {
-            System.err.println( "*** ERROR *** Waterfall requires Java 17 or above to function! Please download and install it!" );
+            System.err.println( "*** ERROR *** XWaterfall requires Java 21 or above to function! Please download and install it!" );
             System.out.println( "You can check your Java version with the command: java -version" );
             return;
         }
